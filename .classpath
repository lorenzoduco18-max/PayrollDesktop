<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<classpathentry including="**/*.java" kind="src" output="target/classes" path="src">
		<attributes>
			<attribute name="optional" value="true"/>
			<attribute name="maven.pomderived" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry excluding="**" kind="src" output="target/classes" path="RESOURCES">
		<attributes>
			<attribute name="maven.pomderived" value="true"/>
			<attribute name="optional" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="lib" path="lib/flatlaf-3.7.jar"/>
	<classpathentry kind="lib" path="lib/commons-logging-1.2.jar"/>
	<classpathentry kind="lib" path="lib/fontbox-2.0.29.jar"/>
	<classpathentry kind="lib" path="lib/pdfbox-2.0.29.jar"/>
	<classpathentry kind="lib" path="lib/mysql-connector-j-9.5.0.jar"/>
	<classpathentry kind="lib" path="lib/openpdf-1.3.32.jar"/>
	<classpathentry kind="lib" path="lib/jakarta.mail-2.0.1.jar"/>
	<classpathentry kind="lib" path="lib/jakarta.activation-2.0.1.jar"/>
	<classpathentry kind="lib" path="lib/webcam-capture-0.3.12.jar"/>
	<classpathentry kind="lib" path="lib/bridj-0.7.0.jar"/>
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER/org.eclipse.jdt.internal.debug.ui.launcher.StandardVMType/JavaSE-17">
		<attributes>
			<attribute name="maven.pomderived" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="con" path="org.eclipse.m2e.MAVEN2_CLASSPATH_CONTAINER">
		<attributes>
			<attribute name="maven.pomderived" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="output" path="target/classes"/>
</classpath>
